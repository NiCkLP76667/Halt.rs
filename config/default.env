# Halt.rs Configuration

# Server Configuration
HALT_HOST=127.0.0.1
HALT_PORT=8080

# Circuit Breaker Configuration
HALT_CIRCUIT_THRESHOLD=5
HALT_CIRCUIT_WINDOW_SECONDS=30

# Backpressure Queue Configuration
HALT_QUEUE_CAPACITY=1000

# Database Configuration
HALT_DATABASE_PATH=./halt.db
HALT_DATABASE_CONNECTION_POOL_SIZE=10

# Audit Logging Configuration
HALT_AUDIT_MAX_ENTRIES=10000
HALT_AUDIT_RETENTION_DAYS=30

# Metrics Configuration
HALT_METRICS_ENABLED=true
HALT_METRICS_INTERVAL_SECONDS=60

# WebSocket Configuration
HALT_WS_MAX_CONNECTIONS=1000
HALT_WS_HEARTBEAT_INTERVAL_SECONDS=30

# Security Configuration
HALT_API_KEY_ENABLED=false
HALT_API_KEY_VALUE=
HALT_CORS_ENABLED=true
HALT_CORS_ORIGINS=*

# Logging Configuration
HALT_LOG_LEVEL=info
HALT_LOG_FORMAT=json
HALT_LOG_FILE=./logs/halt.log

# Performance Configuration
HALT_WORKER_THREADS=4
HALT_MAX_BLOCKING_THREADS=512

# MCP Server Configuration
HALT_MCP_ENABLED=true
HALT_MCP_TOOLS_ENABLED=true
HALT_MCP_RESOURCES_ENABLED=true

# Python Bindings Configuration
HALT_PYTHON_REQUEST_TIMEOUT=5.0
HALT_PYTHON_MAX_RETRIES=3

# TypeScript/JavaScript Configuration
HALT_TS_RECONNECT_INTERVAL_MS=5000
HALT_TS_MAX_RECONNECT_ATTEMPTS=10

# Java Configuration
HALT_JAVA_LIBRARY_PATH=./lib
HALT_JAVA_CLASS_PATH=.

# Cross-IDE Support
HALT_IDE_CURSOR_ENABLED=true
HALT_IDE_VSCODE_ENABLED=true
HALT_IDE_ZED_ENABLED=true
HALT_IDE_JETBRAINS_ENABLED=true
